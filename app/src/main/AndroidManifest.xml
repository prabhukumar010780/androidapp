<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="com.android.vending.BILLING" />

    <application
        android:name=".DestinyApp"
        android:allowBackup="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Android_app">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Android_app">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              OAuth / magic-link redirect intent-filter.
              Mirrors iOS Info.plist CFBundleURLTypes (Google Sign-In OAuth + universal-link parity).
              Scheme is the reverse-DNS of the application ID; backend redirects to
              destinyai-astrology://auth-callback after OAuth / email magic-link.
              CredentialManager Google Sign-In itself does not require this — only present
              for OAuth redirect flows and email magic-link parity with iOS.
            -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:scheme="destinyai-astrology"
                    android:host="auth-callback" />
            </intent-filter>
        </activity>

        <service
            android:name=".services.DestinyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!--
          FCM default notification channel + icon — parity with iOS APNS configuration.
          channel id must match the channel created at runtime in DestinyApp/notifications setup.
        -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="destiny_default" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.destinyai.astrology.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>