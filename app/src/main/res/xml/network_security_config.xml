<?xml version="1.0" encoding="utf-8"?>
<!--
  Canonical fallback network security config.
  Production / staging release builds inherit this HTTPS-only policy.
  Debug builds override via app/src/debug/res/xml/network_security_config.xml
  to permit cleartext to 10.0.2.2 / localhost / 127.0.0.1 for the local FastAPI dev server.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
